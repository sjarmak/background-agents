{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Cross-Repo Invariant Definitions",
  "description": "Schema for .github/invariants.yml — validated before each CI run",
  "type": "object",
  "required": ["invariants"],
  "additionalProperties": false,
  "properties": {
    "invariants": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "description",
          "severity",
          "search",
          "assertion",
          "message"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$",
            "description": "Unique kebab-case identifier"
          },
          "description": {
            "type": "string",
            "minLength": 10
          },
          "severity": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low"]
          },
          "search": {
            "type": "object",
            "required": ["pattern"],
            "additionalProperties": false,
            "properties": {
              "pattern": {
                "type": "string",
                "minLength": 1,
                "description": "Regex to find candidate code via Sourcegraph"
              },
              "language": {
                "type": "string",
                "description": "Optional language filter (e.g. go, typescript)"
              }
            }
          },
          "assertion": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "must_contain": {
                "type": "string",
                "description": "Regex that must also exist (violation if missing)"
              },
              "must_not_contain": {
                "type": "string",
                "description": "Regex that must NOT exist (violation if found)"
              },
              "must_not_exist": {
                "type": "boolean",
                "const": true,
                "description": "Any search match is itself a violation"
              },
              "scope": {
                "type": "string",
                "enum": ["repo", "file"],
                "default": "repo"
              }
            },
            "oneOf": [
              { "required": ["must_contain", "scope"] },
              { "required": ["must_not_contain", "scope"] },
              { "required": ["must_not_exist"] }
            ]
          },
          "message": {
            "type": "string",
            "minLength": 10,
            "description": "Human-readable violation explanation"
          }
        }
      }
    }
  }
}
