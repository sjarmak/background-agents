// Element kinds, tags, and custom colors for the Cross-Repo Invariant
// Verifier architecture model.
//
// Tags encode delivery state so opt-in / planned work is visually distinct
// from what is already built and exercised by CI:
//   #built     — code path exists and is exercised (workflows / tests run it)
//   #evolving  — built, but the contract/coverage is still moving (opt-in MCP)
//   #planned   — designed/sketched, not yet implemented
//   #research  — speculative track (none in this repo today)

specification {

  element actor {
    style {
      shape person
      color secondary
    }
  }

  element externalSystem {
    style {
      shape rectangle
      color slate
    }
  }

  element system

  element container {
    style {
      shape rectangle
    }
  }

  element component

  element datastore {
    style {
      shape cylinder
    }
  }

  // Deployment model — where each piece runs at review time.
  deploymentNode host {
    style {
      shape rectangle
      color slate
    }
  }
  deploymentNode proc

  tag built {
    color #16a34a
  }
  tag evolving {
    color #d97706
  }
  tag planned {
    color #64748b
  }
  tag research {
    color #6366f1
  }

  // Cross-cutting: carried by any element that is a known risk / open question
  // for the design review (in addition to its delivery-state tag).
  tag risk {
    color #dc2626
  }
}
