{
  "mcpServers": {
    "sourcegraph": {
      "command": "npx",
      "args": [
        "-y",
        "--package",
        "@nicepkg/sourcegraph-mcp@1.3.0",
        "sourcegraph-mcp"
      ],
      "env": {
        "SRC_ENDPOINT": "${SOURCEGRAPH_ENDPOINT}",
        "SRC_ACCESS_TOKEN": "${SOURCEGRAPH_TOKEN}"
      }
    }
  }
}
